# ============================================
# FlowerStudio — Variabili d'Ambiente
# ============================================
# Copia questo file come .env e inserisci i tuoi valori reali:
#   cp .env.example .env

# --- Server ---
PORT=3000

# --- Database PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=FlowerStudio

# --- Autenticazione JWT ---
JWT_SECRET=your_jwt_secret_here

# --- Chatbot AI (Groq) ---
BOT_NAME=Fleur
GROQ_API_KEY=gsk_your_groq_api_key_here
